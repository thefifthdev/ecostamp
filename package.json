{
  "name": "ecostamp",
  "version": "1.0.0",
  "private": true,
  "description": "EcoStamp — Verifiable Travel Impact Protocol on Stacks Bitcoin L2",
  "scripts": {
    "deploy:phase1": "node deploy/deploy-phase1.js",
    "deploy:phase3": "node deploy/deploy-phase-3.js",
    "deploy:phase5": "node deploy/deploy-phase-5.js",
    "oracle:keygen": "node oracle/src/keygen.js",
    "oracle:dev": "cd oracle && npm install && node --watch src/index.js",
    "oracle:start": "cd oracle && node src/index.js",
    "content-server": "cd content-server && npm start",
    "content-server:dev": "cd content-server && npm run dev",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "dev": "node scripts/dev.js",
    "install:all": "cd frontend && npm install && cd ../deploy && npm install && cd ../content-server && npm install && cd ../oracle && npm install"
  },
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "secp256k1": "^5.0.1"
  }
}
